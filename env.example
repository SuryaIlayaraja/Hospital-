# ======================================================
# FRONTEND ENVIRONMENT VARIABLES (Vite / Vercel / Netlify)
# Copy this file as .env and fill in your values.
# ======================================================

# URL of your deployed backend API (e.g., https://your-backend.onrender.com/api)
VITE_API_URL=https://your-backend.onrender.com/api

# Google OAuth Client ID (optional)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Supabase (get from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clerk Auth (get from Clerk dashboard → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-publishable-key
