# ======================================================
# BACKEND ENVIRONMENT VARIABLES (Node / Render / Railway)
# Copy this file as .env and fill in your values.
# ======================================================

# App
PORT=5000
NODE_ENV=production

# Frontend URL (comma-separated if multiple, e.g. Vercel preview + production)
# This controls which origins are allowed by CORS.
FRONTEND_URL=https://your-frontend.vercel.app

# Supabase (get from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT (generate a strong random secret for production)
JWT_SECRET=your-very-strong-random-secret-here
JWT_EXPIRES_IN=7d
PATIENT_JWT_EXPIRES_IN=7d

# Clerk (get from Clerk dashboard → API Keys → Secret key)
CLERK_SECRET_KEY=sk_live_your-clerk-secret-key

# Email (Gmail App Password — https://myaccount.google.com/apppasswords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Optional OTP settings
OTP_HASH_SECRET=your-otp-hash-secret
OTP_TTL_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
