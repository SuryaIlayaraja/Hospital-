# Supabase (required): Project Settings → API → URL and service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
PATIENT_JWT_EXPIRES_IN=7d
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Clerk (backend): Dashboard → API Keys → Secret key — required for GET /api/tickets/mine (patient ticket list)
CLERK_SECRET_KEY=

# Optional OTP
OTP_HASH_SECRET=
OTP_TTL_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=30
